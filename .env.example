STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY

# Node server.js — contact_unlocks after Stripe Checkout (service role bypasses RLS)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
# Public HTTPS origin for Flutter + Stripe success/cancel redirects (no trailing slash).
# Not http://localhost:4000 / 127.0.0.1 on real devices. Not port 4040 (that's ngrok's web UI).
API_URL=https://YOUR_TUNNEL.ngrok-free.app
# Optional override for Stripe return URLs only (defaults to API_URL).
# PUBLIC_BASE_URL=https://YOUR_TUNNEL.ngrok-free.app
# Node: POST /create-payment (Stripe Checkout), POST /verify-payment (session_id → contact_unlocks).
# Optional overrides (defaults use tattsbid:// deep links).
# STRIPE_SUCCESS_URL=tattsbid://checkout/success?session_id={CHECKOUT_SESSION_ID}&kind=deposit
# STRIPE_CANCEL_URL=tattsbid://checkout/cancel?kind=deposit
